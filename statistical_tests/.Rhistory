library(readxl)
Alle_Ergebnisse_Bachelorarbeit <- read_excel("C:/Users/ronal/OneDrive/Alle Ergebnisse Bachelorarbeit.xlsx")
View(Alle_Ergebnisse_Bachelorarbeit)
View(Alle_Ergebnisse_Bachelorarbeit)
# Arbeitskopie anlegen
df <- Alle_Ergebnisse_Bachelorarbeit
# Überblick
str(df)
names(df)
# 1) Leere Spalten entfernen (falls durch ;; am Ende entstanden)
df <- df[, colSums(!is.na(df) & df != "") > 0]
# Spaltennamen bereinigen
names(df) <- trimws(names(df))
names(df) <- gsub("-", "_", names(df))
names(df) <- gsub(" ", "_", names(df))
# Kontrolle
names(df)
# 2) Nur echte Iterationen behalten, also Gesamt-Zeilen entfernen
# Falls Iteration als Text importiert wurde:
df$Iteration <- trimws(as.character(df$Iteration))
df <- df[df$Iteration != "Gesamt", ]
# Optional: Iteration numerisch machen
df$Iteration <- as.numeric(df$Iteration)
# 3) Strings bereinigen
char_cols <- sapply(df, is.character)
df[char_cols] <- lapply(df[char_cols], trimws)
# 4) passed/failed in 1/0 umwandeln
convert_pass_fail <- function(x) {
x <- tolower(trimws(as.character(x)))
ifelse(x == "passed", 1,
ifelse(x == "failed", 0, NA))
}
# Nur umwandeln, wenn die Spalten existieren
if ("Diff" %in% names(df)) df$Diff <- convert_pass_fail(df$Diff)
if ("Test" %in% names(df)) df$Test <- convert_pass_fail(df$Test)
if ("Refactoring_Check" %in% names(df)) df$Refactoring_Check <- convert_pass_fail(df$Refactoring_Check)
if ("Refactoring.check" %in% names(df)) {
df$Refactoring_Check <- convert_pass_fail(df$Refactoring.check)
df$Refactoring.check <- NULL
}
if ("Gesamt" %in% names(df)) df$Gesamt <- convert_pass_fail(df$Gesamt)
# 5) Falls Kommazahlen/Prozentwerte irgendwo noch vorkommen, hier optional bereinigen
# Für die Regression nicht nötig, solange Gesamt sauber 0/1 ist
# 6) Faktoren setzen
if ("Sprache" %in% names(df)) {
df$Sprache <- factor(df$Sprache)
}
if ("Projekt" %in% names(df)) {
df$Projekt <- factor(df$Projekt)
}
if ("Komplexität" %in% names(df)) {
df$Komplexität <- factor(df$Komplexität,
levels = c("gering", "mittel", "komplex"))
}
if ("Refactoring" %in% names(df)) {
df$Refactoring <- factor(df$Refactoring)
}
if ("schwierigkeit" %in% names(df)) {
df$schwierigkeit <- factor(df$schwierigkeit,
levels = c("einfach", "mittel", "schwierig"))
}
if ("LLM" %in% names(df)) {
df$LLM <- factor(df$LLM)
}
# 7) Prüfen, ob alles sauber ist
str(df)
summary(df$Gesamt)
table(df$Komplexität, useNA = "ifany")
table(df$LLM, useNA = "ifany")
table(df$Sprache, useNA = "ifany")
# 8) Kontrolltabelle: Erfolgsraten nach Komplexität
aggregate(Gesamt ~ Komplexität, data = df, mean)
# Optional schöner in Prozent:
aggregate(Gesamt ~ Komplexität, data = df, function(x) round(mean(x) * 100, 2))
# Auch nach Modell:
aggregate(Gesamt ~ Komplexität + LLM, data = df, function(x) round(mean(x) * 100, 2))
# 9) Einfache logistische Regression
model_glm_1 <- glm(Gesamt ~ Komplexität + LLM + Sprache,
data = df,
family = binomial)
summary(model_glm_1)
# Odds Ratios
exp(coef(model_glm_1))
# 10) Logistische Regression mit Interaktion Komplexität x LLM
model_glm_2 <- glm(Gesamt ~ Komplexität * LLM + Sprache,
data = df,
family = binomial)
summary(model_glm_2)
# Odds Ratios
exp(coef(model_glm_2))
# 11) Modellvergleich: bringt die Interaktion etwas?
anova(model_glm_1, model_glm_2, test = "Chisq")
# 12) Optional: Refactoring als Kontrollvariable ergänzen
model_glm_3 <- glm(Gesamt ~ Komplexität * LLM + Sprache + Refactoring,
data = df,
family = binomial)
summary(model_glm_3)
exp(coef(model_glm_3))
# 13) Noch besser: Schwierigkeit als Kontrollvariable statt/nach Refactoring
model_glm_4 <- glm(Gesamt ~ Komplexität * LLM + Sprache + schwierigkeit,
data = df,
family = binomial)
summary(model_glm_4)
exp(coef(model_glm_4))
# 14) Falls du ein Mixed Model willst:
# install.packages("lme4")
library(lme4)
model_mixed <- glmer(Gesamt ~ Komplexität * LLM + Sprache + (1 | Projekt) + (1 | Refactoring),
data = df,
family = binomial)
summary(model_mixed)
# Odds Ratios der festen Effekte
exp(fixef(model_mixed))
# 15) Nützliche Kreuztabellen
table(df$Komplexität, df$Gesamt)
prop.table(table(df$Komplexität, df$Gesamt), margin = 1)
table(df$Komplexität, df$LLM, df$Gesamt)
# 16) Falls du die bereinigte Datei speichern willst
write.csv2(df, "Alle_Ergebnisse_Bachelorarbeit_bereinigt.csv", row.names = FALSE)
summary(model_glm_1)
summary(model_glm_2)
anova(model_glm_1, model_glm_2, test = "Chisq")
exp(coef(model_glm_1))
summary(model_glm_3)
results <- summary(model_glm_2)$coefficients
table_reg <- data.frame(
Variable = rownames(results),
Estimate = results[,1],
Std_Error = results[,2],
z_value = results[,3],
p_value = results[,4],
Odds_Ratio = exp(results[,1])
)
print(table_reg)
tab <- table(
Refactoring = df$Refactoring_check,
Test = df$Test
)
tab
library(dplyr)
library(tidyr)
# -----------------------------
# 1. Hilfsspalten
# -----------------------------
df2 <- df %>%
mutate(
ref_ok = Refactoring_check == "passed",
test_ok = Test == 1,
diff_ok = Diff == 1,
success = Gesamt == 1
)
# -----------------------------
# 2. Überblick zentraler Ergebnisse nach Komplexitätsstufe
# -----------------------------
# Erfolgsraten nach Sprache und Komplexität
success_language_complexity <- df2 %>%
group_by(Sprache, Komplexität) %>%
summarise(rate = mean(success) * 100, .groups = "drop") %>%
pivot_wider(names_from = Komplexität, values_from = rate)
success_language_total <- df2 %>%
group_by(Sprache) %>%
summarise(Gesamt = mean(success) * 100, .groups = "drop")
success_language_complexity <- success_language_complexity %>%
left_join(success_language_total, by = "Sprache")
success_language_complexity
# Gesamte Erfolgsrate nach Komplexität
success_total_complexity <- df2 %>%
group_by(Komplexität) %>%
summarise(rate = mean(success) * 100, .groups = "drop") %>%
pivot_wider(names_from = Komplexität, values_from = rate)
success_total_all <- df2 %>%
summarise(Gesamt = mean(success) * 100)
success_total_complexity <- bind_cols(success_total_complexity, success_total_all)
success_total_complexity
# Prozessmetriken nach Komplexität
process_metrics <- df2 %>%
group_by(Komplexität) %>%
summarise(
`Änderung vorgenommen` = mean(diff_ok) * 100,
`Refactoring korrekt umgesetzt` = mean(ref_ok) * 100,
`Tests bestanden` = mean(test_ok) * 100,
.groups = "drop"
)
process_metrics_total <- df2 %>%
summarise(
Komplexität = "Gesamt",
`Änderung vorgenommen` = mean(diff_ok) * 100,
`Refactoring korrekt umgesetzt` = mean(ref_ok) * 100,
`Tests bestanden` = mean(test_ok) * 100
)
process_metrics_all <- bind_rows(process_metrics, process_metrics_total)
process_metrics_all
# Modelle nach Komplexität
model_metrics <- df2 %>%
group_by(LLM, Komplexität) %>%
summarise(rate = mean(success) * 100, .groups = "drop") %>%
pivot_wider(names_from = Komplexität, values_from = rate)
model_metrics_total <- df2 %>%
group_by(LLM) %>%
summarise(Gesamt = mean(success) * 100, .groups = "drop")
model_metrics <- model_metrics %>%
left_join(model_metrics_total, by = "LLM")
model_metrics
# -----------------------------
# 3. Weitere Kennzahlen
# -----------------------------
# Bestes / schwächstes Refactoring nach Erfolgsrate
ref_success <- df2 %>%
group_by(Refactoring) %>%
summarise(
erfolgsrate = mean(success) * 100,
.groups = "drop"
)
best_refactoring <- ref_success %>%
slice_max(erfolgsrate, n = 1)
worst_refactoring <- ref_success %>%
slice_min(erfolgsrate, n = 1)
best_refactoring
worst_refactoring
# -----------------------------
# 4. Standardabweichung der Erfolgsraten
# -----------------------------
# Wichtig: hier Standardabweichung der Einzeliterationen von success (0/1)
# über alle Zeilen je Refactoring
ref_sd <- df2 %>%
group_by(Refactoring) %>%
summarise(
std = sd(as.numeric(success)) * 100,
.groups = "drop"
)
most_stable <- ref_sd %>%
slice_min(std, n = 1)
least_stable <- ref_sd %>%
slice_max(std, n = 1)
mean_sd <- df2 %>%
summarise(std = sd(as.numeric(success)) * 100)
ref_sd
most_stable
least_stable
mean_sd
# -----------------------------
# 5. Totalausfälle je Modell
# -----------------------------
# Definition:
# Kombination aus Projekt, Refactoring und LLM
# gilt als Totalausfall, wenn in allen 10 Iterationen success == 0
total_failures <- df2 %>%
group_by(LLM, Projekt, Refactoring) %>%
summarise(
successes = sum(success),
total_failure = successes == 0,
.groups = "drop"
)
total_failures_summary <- total_failures %>%
group_by(LLM) %>%
summarise(
totalausfaelle = sum(total_failure),
kombinationen = n(),
prozent = 100 * totalausfaelle / kombinationen,
.groups = "drop"
)
total_failures_summary
# -----------------------------
# 6. Falls du die Standardabweichung je Refactoring
#    über Aggregatwerte pro Kombination willst
#    (oft sinnvoller für deine Tabellen)
# -----------------------------
# Erst Erfolgsrate je Kombination aus Projekt, Refactoring, LLM bilden,
# dann darüber SD je Refactoring berechnen.
combo_rates <- df2 %>%
group_by(Projekt, Refactoring, LLM) %>%
summarise(
erfolgsrate = mean(success) * 100,
.groups = "drop"
)
ref_sd_combo <- combo_rates %>%
group_by(Refactoring) %>%
summarise(
std = sd(erfolgsrate),
.groups = "drop"
)
most_stable_combo <- ref_sd_combo %>%
slice_min(std, n = 1)
least_stable_combo <- ref_sd_combo %>%
slice_max(std, n = 1)
mean_sd_combo <- ref_sd_combo %>%
summarise(durchschnitt = mean(std))
ref_sd_combo
most_stable_combo
least_stable_combo
mean_sd_combo
# -----------------------------
# 7. Kompakt zusammengefasste Ausgabe
# -----------------------------
cat("\n--- Bestes Refactoring ---\n")
print(best_refactoring)
cat("\n--- Schwächstes Refactoring ---\n")
print(worst_refactoring)
cat("\n--- Höchste Stabilität (kleinste SD, Kombinationsebene) ---\n")
print(most_stable_combo)
cat("\n--- Geringste Stabilität (größte SD, Kombinationsebene) ---\n")
print(least_stable_combo)
cat("\n--- Totalausfälle ---\n")
print(total_failures_summary)
cat("\n--- Durchschnittliche Standardabweichung ---\n")
print(mean_sd_combo)
# Pakete installieren (einmalig)
install.packages("pwr")
library(pwr)
# Deine Erfolgsraten pro Projekt (aus Tabelle 4.1)
# Jeweils: gering, mittel, komplex – pro Projekt ein Wert
gering  <- c(0.7083, ...)  # deine 3 Python + 3 Apex Werte für niedrige COC
library(dplyr)
# Erfolgsraten pro Projekt aggregieren
# Passe die Spaltennamen ggf. an deine echten Spaltennamen an
project_rates <- df %>%
group_by(project, complexity) %>%
summarise(success_rate = mean(success == TRUE | success == 1), .groups = "drop")
df
library(dplyr)
library(pwr)
# Erfolgsrate pro Projekt (über alle Refactorings, LLMs und Iterationen)
project_rates <- df %>%
group_by(Projekt, Komplexität) %>%
summarise(success_rate = mean(Gesamt), .groups = "drop")
print(project_rates)
# Vektoren nach Komplexitätsstufe
gering  <- project_rates %>% filter(Komplexität == "gering")  %>% pull(success_rate)
mittel  <- project_rates %>% filter(Komplexität == "mittel")  %>% pull(success_rate)
komplex <- project_rates %>% filter(Komplexität == "komplex") %>% pull(success_rate)
# Cohen's d: gering vs. komplex (matched pairs)
diff <- komplex - gering
d_berechnet <- mean(diff) / sd(diff)
cat("Tatsächliches Cohen's d:", round(d_berechnet, 3), "\n")
# Post-hoc: Welche Power hatte deine Studie mit n=6?
posthoc <- pwr.t.test(n = 6, d = abs(d_berechnet), sig.level = 0.05,
type = "paired", alternative = "two.sided")
cat("Tatsächliche Power:", round(posthoc$power, 3), "\n")
# A priori mit d=0.5 (medium): Wie viele Projekte nötig?
apriori_medium <- pwr.t.test(d = 0.5, sig.level = 0.05, power = 0.80,
type = "paired", alternative = "two.sided")
cat("Benötigte Projekte (d=0.5):", ceiling(apriori_medium$n), "\n")
# A priori mit deinem echten d: Wie viele Projekte nötig?
apriori_real <- pwr.t.test(d = abs(d_berechnet), sig.level = 0.05, power = 0.80,
type = "paired", alternative = "two.sided")
cat("Benötigte Projekte (echtes d):", ceiling(apriori_real$n), "\n")
