library(readxl)
Alle_Ergebnisse_Bachelorarbeit <- read_excel("C:/Users/ronal/OneDrive/Alle Ergebnisse Bachelorarbeit.xlsx")
View(Alle_Ergebnisse_Bachelorarbeit)
View(Alle_Ergebnisse_Bachelorarbeit)
# Arbeitskopie anlegen
df <- Alle_Ergebnisse_Bachelorarbeit
# Überblick
str(df)
names(df)
# 1) Leere Spalten entfernen (falls durch ;; am Ende entstanden)
df <- df[, colSums(!is.na(df) & df != "") > 0]
# Spaltennamen bereinigen
names(df) <- trimws(names(df))
names(df) <- gsub("-", "_", names(df))
names(df) <- gsub(" ", "_", names(df))
# Kontrolle
names(df)
# 2) Nur echte Iterationen behalten, also Gesamt-Zeilen entfernen
# Falls Iteration als Text importiert wurde:
df$Iteration <- trimws(as.character(df$Iteration))
df <- df[df$Iteration != "Gesamt", ]
# Optional: Iteration numerisch machen
df$Iteration <- as.numeric(df$Iteration)
# 3) Strings bereinigen
char_cols <- sapply(df, is.character)
df[char_cols] <- lapply(df[char_cols], trimws)
# 4) passed/failed in 1/0 umwandeln
convert_pass_fail <- function(x) {
x <- tolower(trimws(as.character(x)))
ifelse(x == "passed", 1,
ifelse(x == "failed", 0, NA))
}
# Nur umwandeln, wenn die Spalten existieren
if ("Diff" %in% names(df)) df$Diff <- convert_pass_fail(df$Diff)
if ("Test" %in% names(df)) df$Test <- convert_pass_fail(df$Test)
if ("Refactoring_Check" %in% names(df)) df$Refactoring_Check <- convert_pass_fail(df$Refactoring_Check)
if ("Refactoring.check" %in% names(df)) {
df$Refactoring_Check <- convert_pass_fail(df$Refactoring.check)
df$Refactoring.check <- NULL
}
if ("Gesamt" %in% names(df)) df$Gesamt <- convert_pass_fail(df$Gesamt)
# 5) Falls Kommazahlen/Prozentwerte irgendwo noch vorkommen, hier optional bereinigen
# Für die Regression nicht nötig, solange Gesamt sauber 0/1 ist
# 6) Faktoren setzen
if ("Sprache" %in% names(df)) {
df$Sprache <- factor(df$Sprache)
}
if ("Projekt" %in% names(df)) {
df$Projekt <- factor(df$Projekt)
}
if ("Komplexität" %in% names(df)) {
df$Komplexität <- factor(df$Komplexität,
levels = c("gering", "mittel", "komplex"))
}
if ("Refactoring" %in% names(df)) {
df$Refactoring <- factor(df$Refactoring)
}
if ("schwierigkeit" %in% names(df)) {
df$schwierigkeit <- factor(df$schwierigkeit,
levels = c("einfach", "mittel", "schwierig"))
}
if ("LLM" %in% names(df)) {
df$LLM <- factor(df$LLM)
}
# 7) Prüfen, ob alles sauber ist
str(df)
summary(df$Gesamt)
table(df$Komplexität, useNA = "ifany")
table(df$LLM, useNA = "ifany")
table(df$Sprache, useNA = "ifany")
# 8) Kontrolltabelle: Erfolgsraten nach Komplexität
aggregate(Gesamt ~ Komplexität, data = df, mean)
# Optional schöner in Prozent:
aggregate(Gesamt ~ Komplexität, data = df, function(x) round(mean(x) * 100, 2))
# Auch nach Modell:
aggregate(Gesamt ~ Komplexität + LLM, data = df, function(x) round(mean(x) * 100, 2))
# 9) Einfache logistische Regression
model_glm_1 <- glm(Gesamt ~ Komplexität + LLM + Sprache,
data = df,
family = binomial)
summary(model_glm_1)
# Odds Ratios
exp(coef(model_glm_1))
# 10) Logistische Regression mit Interaktion Komplexität x LLM
model_glm_2 <- glm(Gesamt ~ Komplexität * LLM + Sprache,
data = df,
family = binomial)
summary(model_glm_2)
# Odds Ratios
exp(coef(model_glm_2))
# 11) Modellvergleich: bringt die Interaktion etwas?
anova(model_glm_1, model_glm_2, test = "Chisq")
# 12) Optional: Refactoring als Kontrollvariable ergänzen
model_glm_3 <- glm(Gesamt ~ Komplexität * LLM + Sprache + Refactoring,
data = df,
family = binomial)
summary(model_glm_3)
exp(coef(model_glm_3))
# 13) Noch besser: Schwierigkeit als Kontrollvariable statt/nach Refactoring
model_glm_4 <- glm(Gesamt ~ Komplexität * LLM + Sprache + schwierigkeit,
data = df,
family = binomial)
summary(model_glm_4)
exp(coef(model_glm_4))
# 14) Falls du ein Mixed Model willst:
# install.packages("lme4")
library(lme4)
model_mixed <- glmer(Gesamt ~ Komplexität * LLM + Sprache + (1 | Projekt) + (1 | Refactoring),
data = df,
family = binomial)
summary(model_mixed)
# Odds Ratios der festen Effekte
exp(fixef(model_mixed))
# 15) Nützliche Kreuztabellen
table(df$Komplexität, df$Gesamt)
prop.table(table(df$Komplexität, df$Gesamt), margin = 1)
table(df$Komplexität, df$LLM, df$Gesamt)
# 16) Falls du die bereinigte Datei speichern willst
write.csv2(df, "Alle_Ergebnisse_Bachelorarbeit_bereinigt.csv", row.names = FALSE)
summary(model_glm_1)
summary(model_glm_2)
anova(model_glm_1, model_glm_2, test = "Chisq")
exp(coef(model_glm_1))
summary(model_glm_3)
results <- summary(model_glm_2)$coefficients
table_reg <- data.frame(
Variable = rownames(results),
Estimate = results[,1],
Std_Error = results[,2],
z_value = results[,3],
p_value = results[,4],
Odds_Ratio = exp(results[,1])
)
print(table_reg)
